---
export const prerender = false;

import '../../assets/global.css';
import { db } from '../../db';
import { engineeringAssets, landingMetadata, capabilities, atsResumes } from '../../db/schema';
import { desc, asc } from 'drizzle-orm';

const dbProjects = await db.select().from(engineeringAssets).orderBy(desc(engineeringAssets.id)).catch(() => []);
const projects = dbProjects.map(p => ({
  ...p,
  tools: (p.technologyStack as string[])?.join(', ') || '',
  description: p.detailedContent
}));
const liveDbMetadata = await db.select().from(landingMetadata).limit(1).then(res => res[0]).catch(() => null);
const allCaps = await db.select().from(capabilities).orderBy(asc(capabilities.orderIndex)).catch(() => []);

const allAtsResumes = await db.select().from(atsResumes).orderBy(desc(atsResumes.updatedAt)).catch(() => []);

type CapItem = typeof allCaps[number];
const groupedCaps = allCaps.reduce((acc: Record<string, CapItem[]>, cap: CapItem) => {
  if (!acc[cap.category]) acc[cap.category] = [];
  acc[cap.category].push(cap);
  return acc;
}, {} as Record<string, CapItem[]>);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cloud Content Controller</title>
  </head>
  <body class="min-h-screen bg-slate-50 flex flex-col font-mono text-slate-800 antialiased selection:bg-blue-500/10">
    
    <header class="w-full bg-white border-b border-slate-200/80 px-8 py-4 flex items-center justify-between sticky top-0 z-50 shadow-sm">
      <div class="flex items-center gap-2 text-sm font-bold tracking-tight">
        <span class="text-blue-600">&gt;_</span>
        <span class="text-slate-900">vaqihdev:</span>
        <span class="text-blue-600">~$</span>
        <span class="ml-2 px-2 py-0.5 text-[10px] bg-blue-50 text-blue-600 border border-blue-100 rounded uppercase tracking-widest font-sans font-normal">Session: Authorized</span>
      </div>
      <h1 class="text-sm font-bold text-slate-500 font-mono uppercase tracking-widest hidden md:block">Cloud Content Controller // v1.0</h1>
      <div>
        <a href="/api/logout" class="px-3 py-1.5 border border-red-200 hover:border-red-300 text-red-500 rounded text-xs font-semibold tracking-wider hover:bg-red-50/50 transition-all">
          DISCONNECT SHELL
        </a>
      </div>
    </header>

    <div class="flex-1 w-full max-w-7xl mx-auto p-6 flex flex-col md:flex-row gap-6 relative">
      
      <aside class="w-full md:w-64 bg-white/95 border border-slate-200 rounded-xl p-4 flex flex-col gap-5 shadow-sm h-fit sticky top-24 backdrop-blur-sm z-30">
        <div class="flex flex-col gap-1">
          <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase mb-1 px-2 font-mono">// CONTENT_DOMAINS</span>
          <button class="w-full text-left px-3 py-2 text-xs font-medium rounded-lg text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-all cursor-pointer" data-tab="landing">Landing Controller</button>
          <button class="w-full text-left px-3 py-2 text-xs font-semibold rounded-lg bg-blue-50 text-blue-600 border border-blue-100/50 transition-all cursor-pointer" data-tab="projects">Projects Matrix</button>
          <button class="w-full text-left px-3 py-2 text-xs font-medium rounded-lg text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-all cursor-pointer" data-tab="logs">Engineering Logs</button>
                    <button class="w-full text-left px-3 py-2 text-xs font-medium rounded-lg text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-all cursor-pointer" data-tab="career">Career Profile</button>
          <button class="w-full text-left px-3 py-2 text-xs font-medium rounded-lg text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-all cursor-pointer" data-tab="media">Media Vault</button>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase mb-1 px-2 font-mono">// OPERATIONS_QUEUE</span>
          <button class="w-full text-left px-3 py-2 text-xs font-medium rounded-lg text-slate-500 hover:bg-slate-50 transition-all cursor-pointer" data-tab="incident">Incident Inbox</button>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase mb-1 px-2 font-mono">// SYSTEM_CONTROL</span>
          <button class="w-full text-left px-3 py-2 text-xs font-medium rounded-lg text-slate-500 hover:bg-slate-50 transition-all cursor-pointer" data-tab="control">Control Plane</button>
        </div>
      </aside>

      <main class="flex-1 flex flex-col gap-6 w-full overflow-hidden">
        
        <div id="panel-landing" class="hidden flex flex-col gap-6 w-full">
          <div class="bg-white border border-slate-200 rounded-xl p-6 flex flex-col gap-4 shadow-sm w-full">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3 font-mono">// METADATA: LANDING CONTROLLER</h3>
            <form id="landing-meta-form" class="flex flex-col gap-4 w-full">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                  <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// HERO_FIRST_NAME</span>
                  <input type="text" name="heroFirstName" value={liveDbMetadata?.heroFirstName || "Muchamad"} class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
                </div>
                <div class="flex flex-col gap-1.5">
                  <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// HERO_LAST_NAME</span>
                  <input type="text" name="heroLastName" value={liveDbMetadata?.heroLastName || "Ghufron Vaqih"} class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
                </div>
              </div>
              <div class="flex flex-col gap-1.5">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// HERO_SUBTITLE</span>
                <input type="text" name="heroSubtitle" value={liveDbMetadata?.heroSubtitle || "[ Cloud Infrastructure Engineer & DevOps Architect ]"} class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
              </div>
              <div class="flex flex-col gap-1.5">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// BIO_STRING</span>
                <textarea name="heroShortBio" rows="3" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500">{liveDbMetadata?.heroShortBio || "An engineer with a developer's soul and a systems architect's vision. I build secure, automated, highly available, and resilient cloud infrastructure that empowers modern engineering teams."}</textarea>
              </div>
              <div class="flex flex-col gap-1.5">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// ABOUT_HEADING</span>
                <input type="text" name="aboutHeading" value={liveDbMetadata?.aboutHeading || "Architecting Cloud Trust"} class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
              </div>
              <div class="flex flex-col gap-1.5">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// ABOUT_LONG_DESCRIPTION</span>
                <textarea name="aboutLongDescription" rows="4" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500">{liveDbMetadata?.aboutLongDesc || "With a deep background in systems architecture and modern web development, I bridge the gap between software engineering and cloud infrastructure. I specialize in building scalable, secure, and resilient systems using Infrastructure as Code (IaC), container orchestration, and continuous delivery pipelines that empower teams to ship faster with confidence."}</textarea>
              </div>
              <div class="flex flex-col gap-1.5">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// CORE_ENGINEERING_DOMAINS (Comma Separated list)</span>
                <textarea name="coreDomains" rows="2" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500">{liveDbMetadata?.coreDomains || "Cloud Architecture, Container Orchestration, CI/CD Pipelines, Infrastructure as Code, Microservices, Zero-Trust Security, Serverless Compute, Database Optimization, Site Reliability Engineering (SRE)"}</textarea>
              </div>
              <button type="submit" id="landing-submit-btn" class="self-end px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-semibold shadow-sm hover:shadow-md transition-all font-mono cursor-pointer">
                [ SAVE METADATA ]
              </button>
            </form>
          </div>
        </div>

        <div id="panel-projects" class="flex flex-col gap-6 w-full">
          
          <div class="w-full bg-white border border-slate-200 rounded-xl p-4 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm">
            <input type="text" placeholder="Search media assets..." class="w-full sm:w-72 pl-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-sans focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
            <div class="flex items-center gap-2 w-full sm:w-auto justify-end">
              <button class="px-3 py-2 border border-slate-200 rounded-lg text-xs font-sans font-medium hover:bg-slate-50 text-slate-600 cursor-pointer">Filter</button>
              <button class="px-3 py-2 border border-slate-200 rounded-lg text-xs font-sans font-medium hover:bg-slate-50 text-slate-600 cursor-pointer">Sort</button>
            </div>
          </div>

          <div class="flex flex-col lg:flex-row gap-6 w-full items-start">
            
            <div class="w-full lg:w-1/3 flex flex-col gap-4">
              <div id="md-dropzone" class="w-full border-2 border-dashed border-slate-200 rounded-xl p-6 bg-slate-50/50 hover:bg-blue-50/10 hover:border-blue-400 transition-all flex flex-col items-center justify-center text-center cursor-pointer min-h-[190px] group">
                <span class="text-2xl group-hover:scale-110 transition-transform duration-200">📄</span>
                <p class="text-xs font-sans text-slate-500 mt-1"><span class="font-bold text-blue-600">Drag & drop</span> your project .md file here, or click to browse</p>
                <span class="text-[9px] font-mono text-slate-400 tracking-wider mt-1 uppercase">// Supports Structural Frontmatter</span>
                <input type="file" id="md-file-input" accept=".md" class="hidden" />
              </div>
            </div>

            <form id="projects-matrix-form" class="w-full lg:w-2/3 bg-white border border-slate-200 rounded-xl p-6 shadow-sm flex flex-col gap-4">
              <div id="edit-mode-badge" class="hidden px-3 py-2 bg-yellow-50 text-yellow-700 border border-yellow-200 rounded-lg text-xs font-mono font-bold flex items-center justify-between gap-2"><span>EDIT MODE - Currently Editing: <span id="edit-mode-title" class="text-yellow-900"></span></span><button type="button" id="cancel-edit-btn" style="position: relative; z-index: 50; pointer-events: auto; cursor: pointer;" class="text-yellow-600 hover:text-yellow-800 underline ml-auto border-none bg-transparent">Cancel</button></div>
              <input type="hidden" id="form-asset-id" value="" />
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex flex-col gap-1">
                  <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// ASSET_TITLE</span>
                  <input type="text" name="title" id="form-title" placeholder="e.g., Enterprise Kubernetes Architecture" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" required />
                </div>
                <div class="flex flex-col gap-1">
                  <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// ASSET_TYPE</span>
                  <select name="type" id="form-type" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" required>
                    <option value="Project">Project</option>
                    <option value="Lab">Lab</option>
                  </select>
                </div>
              </div>
              <div class="flex flex-col gap-1">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// ENGINEERED_TOOLS_STACK</span>
                <input type="text" name="tools" id="form-tools" placeholder="e.g., AWS, Terraform, Docker, ArgoCD" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
              </div>
              <div class="flex flex-col gap-1">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// DOMAIN_DETAILED_DESCRIPTION</span>
                <textarea name="description" id="form-description" rows="6" placeholder="Paste or type extensive execution description details..." class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 resize-y" required></textarea>
              </div>

              <details class="group border border-slate-200 rounded-lg bg-slate-50/30 overflow-hidden">
                <summary class="text-xs font-mono font-bold tracking-widest uppercase text-slate-500 cursor-pointer p-4 select-none hover:bg-slate-50/50 transition-colors">
                  [+] Advanced Engineering Metadata
                </summary>
                <div class="p-4 pt-0 grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-slate-200">
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// STATUS</span>
                    <select name="status" id="form-status" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500">
                      <option value="Completed">Completed</option>
                      <option value="Production">Production</option>
                      <option value="Draft">Draft</option>
                    </select>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// DIFFICULTY</span>
                    <select name="difficulty" id="form-difficulty" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500">
                      <option value="Beginner">Beginner</option>
                      <option value="Intermediate" selected>Intermediate</option>
                      <option value="Advanced">Advanced</option>
                    </select>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// CLOUD_PROVIDER</span>
                    <input type="text" name="cloudProvider" id="form-cloud-provider" placeholder="e.g., AWS, GCP, Vercel" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// OPERATING_SYSTEM</span>
                    <input type="text" name="operatingSystem" id="form-os" placeholder="e.g., Linux, MacOS" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500" />
                  </div>
                </div>
              </details>
              <div class="flex items-center gap-2 py-1 select-none">
                <input type="checkbox" name="isFeatured" id="form-is-featured" class="w-4 h-4 text-blue-600 border-slate-300 rounded focus:ring-blue-500/10 cursor-pointer" />
                <label for="form-is-featured" class="text-[10px] font-mono font-bold tracking-wide text-slate-500 uppercase cursor-pointer">// PROVIDE AS FEATURED PORTFOLIO NODE</label>
              </div>
              <button type="submit" id="projects-submit-btn" class="self-end px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-mono font-semibold shadow-sm hover:shadow-md transition-all duration-150 cursor-pointer">
                [ DEPLOY ASSET TO LIVE LAYER ]
              </button>
            </form>
          </div>

          <section class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm min-h-[260px] flex flex-col justify-between w-full overflow-hidden">
            <div class="w-full">
              <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3 mb-4 font-mono">// ACTIVE_ASSETS: Projects Matrix</h3>
              
              {projects.length === 0 ? (
                <div class="flex flex-col items-center justify-center py-16 text-center">
                  <div class="w-12 h-12 rounded-full bg-slate-50 border border-slate-100 flex items-center justify-center mb-2 text-base shadow-sm">📁</div>
                  <h4 class="text-xs font-bold text-slate-700 font-sans mb-0.5">No assets uploaded</h4>
                  <p class="text-[11px] text-slate-400 font-sans max-w-xs">Provision your first project node into the active Neon table container shell.</p>
                </div>
              ) : (
                <div class="overflow-x-auto w-full">
                  <table class="w-full text-left border-collapse text-xs font-sans">
                    <thead>
                      <tr class="border-b border-slate-100 text-slate-400 font-mono text-[10px] tracking-widest uppercase bg-slate-50/50">
                        <th class="py-3 px-4">ID</th>
                        <th class="py-3 px-4">Asset Title</th>
                        <th class="py-3 px-4">Type</th>
                        <th class="py-3 px-4">Tools Stack</th>
                        <th class="py-3 px-4 text-right">Operational Action</th>
                      </tr>
                    </thead>
                    <tbody id="assets-tbody" class="divide-y divide-slate-100 text-slate-700">
                      {projects.filter(p => p.type && (p.type.toLowerCase() === 'project' || p.type.toLowerCase() === 'lab')).map((proj, i) => (
                        <tr class="hover:bg-slate-50/40 transition-colors duration-100">
                          <td class="py-3 px-4 font-mono text-slate-400">#{i + 1}</td>
                          <td class="py-3 px-4 font-bold text-slate-900">{proj.title}</td>
                          <td class="py-3 px-4">
                            <span class={`px-2 py-0.5 rounded text-[9px] font-mono uppercase tracking-wider ${proj.type === 'Project' ? 'bg-blue-50 text-blue-600 border border-blue-100/60' : 'bg-orange-50 text-orange-600 border border-orange-100/60'}`}>{proj.type}</span>
                          </td>
                          <td class="py-3 px-4 text-slate-500 font-mono max-w-xs truncate">{proj.tools}</td>
                          <td class="py-3 px-4 text-right whitespace-nowrap">
                            <button data-edit-id={proj.id} class="text-blue-500 hover:text-blue-700 font-mono font-bold hover:underline bg-transparent cursor-pointer border-none py-1 px-2 rounded hover:bg-blue-50/30 transition-all mr-2">EDIT</button>
                            <button data-delete-id={proj.id} class="text-red-500 hover:text-red-700 font-mono font-bold hover:underline bg-transparent cursor-pointer border-none py-1 px-2 rounded hover:bg-red-50/30 transition-all">DELETE</button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          </section>

        </div>

        
        <div id="panel-logs" class="hidden flex flex-col gap-8 w-full">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
            <div class="flex flex-col gap-1">
              <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Engineering Logs</h2>
              <p class="text-sm text-slate-500 font-sans">Manage your Cloud & DevOps capability matrix — categories and underlying skills.</p>
            </div>
            <button id="btn-add-category" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-full text-xs font-bold tracking-widest uppercase transition-all shadow-sm flex items-center gap-2 w-fit">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 110 1.5H8.5v4.25a.75.75 0 11-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z"></path></svg>
              ADD CATEGORY
            </button>
          </div>

          <div class="flex flex-col sm:flex-row items-center gap-4 w-full">
            <div class="relative w-full">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M11.5 7a4.499 4.499 0 11-8.998 0A4.499 4.499 0 0111.5 7zm-.82 4.74a6 6 0 111.06-1.06l3.04 3.04a.75.75 0 11-1.06 1.06l-3.04-3.04z"></path></svg>
              <input type="text" placeholder="Search capability categories..." class="w-full pl-9 pr-4 py-2 bg-white border border-slate-200 rounded-lg text-sm text-slate-700 font-sans focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 shadow-sm" />
            </div>
            <div class="flex items-center gap-2">
              <button class="flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-sans font-medium text-slate-600 hover:bg-slate-50 shadow-sm">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M11.5 1h-7a1.5 1.5 0 00-1.5 1.5v1.268a1.5 1.5 0 00.439 1.06L6 7.42V14.5a.5.5 0 00.785.41l2.5-1.75a.5.5 0 00.215-.41V7.42l2.561-2.592a1.5 1.5 0 00.439-1.06V2.5A1.5 1.5 0 0011.5 1zM4.5 2.5a.5.5 0 01.5-.5h7a.5.5 0 01.5.5v1.268a.5.5 0 01-.146.354L9.5 6.92v5.83l-1.5 1.05V6.92L5.146 4.622A.5.5 0 015 4.268V2.5z"></path></svg>
                Filter
              </button>
              <button class="flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-sans font-medium text-slate-600 hover:bg-slate-50 shadow-sm">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M3.22 9.78a.75.75 0 010 1.06l-2.25 2.25a.75.75 0 01-1.06 0l-2.25-2.25a.75.75 0 011.06-1.06l.97.97V.75a.75.75 0 011.5 0v9.94l.97-.97a.75.75 0 011.06 0zM12.78 6.22a.75.75 0 010-1.06l2.25-2.25a.75.75 0 011.06 0l2.25 2.25a.75.75 0 01-1.06 1.06l-.97-.97v9.94a.75.75 0 01-1.5 0V5.06l-.97.97a.75.75 0 01-1.06 0z"></path></svg>
                Sort
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-4 w-full">
            {Object.keys(groupedCaps).length === 0 ? (
               <div class="w-full bg-white border border-slate-200 rounded-xl p-8 text-center shadow-sm">
                 <p class="text-slate-500 font-sans text-sm">No capabilities logged yet.</p>
               </div>
            ) : Object.entries(groupedCaps).map(([category, skills]) => (
              <div class="bg-white border border-slate-200 rounded-xl p-4 sm:p-6 shadow-sm flex flex-col gap-4">
                <div class="flex items-center justify-between pb-2">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded bg-blue-50 flex items-center justify-center text-blue-500">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2 1.75C2 .784 2.784 0 3.75 0h8.5C13.216 0 14 .784 14 1.75v12.5A1.75 1.75 0 0112.25 16h-8.5A1.75 1.75 0 012 14.25V1.75zm1.75-.25a.25.25 0 00-.25.25v12.5c0 .138.112.25.25.25h8.5a.25.25 0 00.25-.25V1.75a.25.25 0 00-.25-.25h-8.5zM6 4a.75.75 0 01.75-.75h2.5a.75.75 0 010 1.5h-2.5A.75.75 0 016 4zm-1 3.5a.75.75 0 01.75-.75h4.5a.75.75 0 010 1.5h-4.5A.75.75 0 015 7.5zm0 3.5a.75.75 0 01.75-.75h4.5a.75.75 0 010 1.5h-4.5a.75.75 0 01-.75-.75z"></path></svg>
                    </div>
                    <h3 class="text-base sm:text-lg font-bold text-slate-900">{category}</h3>
                  </div>
                  <button data-add-skill-cat={category} class="px-3 py-1.5 border border-slate-200 hover:border-blue-300 rounded text-[10px] sm:text-xs font-bold tracking-widest text-blue-500 hover:bg-blue-50 uppercase flex items-center gap-1 transition-all bg-white shadow-sm cursor-pointer">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 110 1.5H8.5v4.25a.75.75 0 11-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z"></path></svg>
                    ADD SKILL
                  </button>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {skills.map((skill) => (
                    <div class="group flex items-center justify-between p-3 border border-slate-100 rounded-lg bg-slate-50/50 hover:bg-white hover:border-slate-300 hover:shadow-sm transition-all">
                      <div class="flex items-center gap-3">
                        <div class="w-1 h-8 rounded-full bg-blue-500"></div>
                        <div class="flex flex-col gap-0.5">
                          <span class="text-sm font-bold text-slate-800 font-sans">{skill.skillName}</span>
                          <span class="text-[9px] font-bold tracking-widest text-blue-500 uppercase flex items-center gap-1">
                            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                            {skill.level}
                          </span>
                        </div>
                      </div>
                      <button data-delete-cap-id={skill.id} class="p-2 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded opacity-0 group-hover:opacity-100 transition-all cursor-pointer">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M6.5 1.75a.25.25 0 01.25-.25h2.5a.25.25 0 01.25.25V3h-3V1.75zm4.5 0V3h2.25a.75.75 0 010 1.5H12.6l-.67 8.042A2.25 2.25 0 019.692 14.5H6.308a2.25 2.25 0 01-2.238-1.958L3.4 4.5H2.75a.75.75 0 010-1.5H5V1.75C5 .784 5.784 0 6.75 0h2.5C10.216 0 11 .784 11 1.75zM4.91 4.5l.661 7.925A.75.75 0 006.308 13h3.384a.75.75 0 00.746-.675L11.09 4.5H4.91z"></path></svg>
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div id="panel-career" class="hidden flex flex-col gap-6 w-full">
          <div class="flex items-center justify-between bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
            <div>
              <h3 class="text-lg font-bold text-slate-800">ATS Resume Builder</h3>
              <p class="text-xs text-slate-500 mt-1">Manage and edit your ATS-friendly resumes</p>
            </div>
            <button id="create-resume-btn" class="px-5 py-2.5 bg-slate-900 hover:bg-slate-800 text-white rounded-lg text-xs font-semibold shadow-sm transition-all flex items-center gap-2 cursor-pointer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              Create New Resume
            </button>
          </div>

          <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden w-full">
            {allAtsResumes.length === 0 ? (
              <div class="p-12 text-center flex flex-col items-center justify-center">
                <div class="p-4 bg-blue-50 rounded-full text-blue-500 mb-3">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <h4 class="text-sm font-bold text-slate-700">No Resumes Found</h4>
                <p class="text-xs text-slate-500 mt-1">Create your first resume to get started!</p>
              </div>
            ) : (
              <div class="overflow-x-auto w-full">
                <table class="w-full text-left border-collapse font-sans text-sm min-w-[600px]">
                  <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50 text-slate-400 font-mono text-[10px] uppercase tracking-widest">
                      <th class="py-3 px-6">Title</th>
                      <th class="py-3 px-6">Template</th>
                      <th class="py-3 px-6">Last Updated</th>
                      <th class="py-3 px-6 text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    {allAtsResumes.map(resume => {
                      const dateObj = new Date(resume.updatedAt);
                      const displayDate = isNaN(dateObj.getTime()) ? 'Unknown Date' : dateObj.toLocaleString();
                      return (
                      <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="py-4 px-6 font-semibold text-slate-800">{resume.title}</td>
                        <td class="py-4 px-6 text-slate-500 capitalize">{resume.template}</td>
                        <td class="py-4 px-6 text-slate-500 text-xs">{displayDate}</td>
                        <td class="py-4 px-6 text-right space-x-2">
                          <a href={`/admin/builder?id=${resume.id}`} class="inline-flex items-center justify-center px-3 py-1.5 bg-blue-50 text-blue-600 hover:bg-blue-100 rounded text-xs font-medium transition-colors">Edit</a>
                          <button data-delete-resume-id={resume.id} class="inline-flex items-center justify-center px-3 py-1.5 bg-red-50 text-red-600 hover:bg-red-100 rounded text-xs font-medium transition-colors cursor-pointer border-none outline-none">Delete</button>
                        </td>
                      </tr>
                      )
                    })}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>
      </main>
    </div>

    <div id="capability-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center p-4">
      <div class="bg-white border border-slate-200 rounded-xl shadow-xl w-full max-w-md overflow-hidden flex flex-col">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
          <h3 id="modal-title" class="text-sm font-bold text-slate-800 tracking-wide font-sans">Add Capability</h3>
          <button id="modal-close" class="text-slate-400 hover:text-slate-600 transition-colors cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M3.72 3.72a.75.75 0 011.06 0L8 6.94l3.22-3.22a.75.75 0 111.06 1.06L9.06 8l3.22 3.22a.75.75 0 11-1.06 1.06L8 9.06l-3.22 3.22a.75.75 0 01-1.06-1.06L6.94 8 3.72 4.78a.75.75 0 010-1.06z"></path></svg>
          </button>
        </div>
        <form id="capability-form" class="flex flex-col gap-5 p-6">
          <div class="flex flex-col gap-1.5" id="category-group">
            <label class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// CATEGORY_NAME</label>
            <input type="text" id="modal-category" name="category" placeholder="e.g., Backend, Infrastructure" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-sm font-sans focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" required />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// SKILL_NAME</label>
            <input type="text" id="modal-skill" name="skill" placeholder="e.g., Node.js, Kubernetes" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-sm font-sans focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" required />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold tracking-widest text-slate-400 uppercase font-mono">// PROFICIENCY_LEVEL</label>
            <select id="modal-level" name="level" class="w-full px-3 py-2 border border-slate-200 bg-slate-50/50 rounded-lg text-sm font-sans focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-slate-700">
              <option value="BEGINNER">BEGINNER</option>
              <option value="INTERMEDIATE" selected>INTERMEDIATE</option>
              <option value="ADVANCED">ADVANCED</option>
              <option value="EXPERT">EXPERT</option>
            </select>
          </div>
          <div class="flex items-center justify-end gap-3 mt-2">
            <button type="button" id="modal-cancel" class="px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 rounded-lg transition-colors cursor-pointer">CANCEL</button>
            <button type="submit" id="modal-submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-bold tracking-widest uppercase transition-all shadow-sm cursor-pointer">SAVE</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      // @ts-nocheck
      document.addEventListener('DOMContentLoaded', () => {
        const tabs = document.querySelectorAll('[data-tab]');
        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('bg-blue-50', 'text-blue-600', 'font-semibold', 'border', 'border-blue-100/50'));
            tab.classList.add('bg-blue-50', 'text-blue-600', 'font-semibold', 'border', 'border-blue-100/50');
            
            const target = tab.getAttribute('data-tab');
            ['panel-landing', 'panel-projects', 'panel-logs', 'panel-career'].forEach(pId => {
              const panel = document.getElementById(pId);
              if (panel) {
                if (pId === `panel-${target}`) panel.classList.remove('hidden');
                else panel.classList.add('hidden');
              }
            });
          });
        });

        
        const dropzoneBlogs = document.getElementById('md-dropzone-blogs');
        const fileInputBlogs = document.getElementById('md-file-input-blogs');

        if (dropzoneBlogs && fileInputBlogs) {
          dropzoneBlogs.addEventListener('click', () => fileInputBlogs.click());

          ['dragenter', 'dragover'].forEach(name => {
            dropzoneBlogs.addEventListener(name, (e) => {
              e.preventDefault();
              dropzoneBlogs.classList.add('border-blue-500', 'bg-blue-50');
            });
          });

          ['dragleave', 'drop'].forEach(name => {
            dropzoneBlogs.addEventListener(name, (e) => {
              e.preventDefault();
              dropzoneBlogs.classList.remove('border-blue-500', 'bg-blue-50');
            });
          });

          dropzoneBlogs.addEventListener('drop', (e) => {
            e.preventDefault();
            const files = e.dataTransfer.files;
            if (files.length) executeMarkdownIngestionBlogs(files[0]);
          });
          
          fileInputBlogs.addEventListener('change', (e) => {
             if (e.target.files.length > 0) {
                 executeMarkdownIngestionBlogs(e.target.files[0]);
             }
          });
        }

        const dropzone = document.getElementById('md-dropzone');
        const fileInput = document.getElementById('md-file-input');

        if (dropzone && fileInput) {
          dropzone.addEventListener('click', () => fileInput.click());

          ['dragenter', 'dragover'].forEach(name => {
            dropzone.addEventListener(name, (e) => {
              e.preventDefault();
              dropzone.classList.add('border-blue-500', 'bg-blue-50/30');
            });
          });

          ['dragleave', 'drop'].forEach(name => {
            dropzone.addEventListener(name, (e) => {
              e.preventDefault();
              dropzone.classList.remove('border-blue-500', 'bg-blue-50/30');
            });
          });

          dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            const files = e.dataTransfer.files;
            if (files.length) executeMarkdownIngestion(files[0]);
          });

          fileInput.addEventListener('change', (e) => {
            if (e.target.files.length) executeMarkdownIngestion(e.target.files[0]);
          });
        }

        function executeMarkdownIngestion(file) {
          if (!file.name.endsWith('.md')) return alert('❌ Security Block: Only standard Markdown (.md) structures are accepted.');
          
          const reader = new FileReader();
          reader.onload = (e) => {
            const content = e.target.result;
            const frontmatterMatch = content.match(/^---\s*([\s\S]*?)\n---\s*([\s\S]*)$/);
            
            let meta = {}, bodyText = content;
            if (frontmatterMatch) {
              frontmatterMatch[1].split('\n').forEach(line => {
                const parts = line.split(':');
                if (parts.length >= 2) {
                  const key = parts[0].trim();
                  const val = parts.slice(1).join(':').trim().replace(/^["']|["']$/g, '');
                  meta[key] = val;
                }
              });
              bodyText = frontmatterMatch[2].trim();
            }

            if (meta.title) document.getElementById('form-title').value = meta.title;
            if (meta.type) document.getElementById('form-type').value = meta.type;
            if (meta.tools) document.getElementById('form-tools').value = meta.tools;
            if (meta.isFeatured) {
              document.getElementById('form-is-featured').checked = (meta.isFeatured === 'true' || meta.isFeatured === true);
            }
            document.getElementById('form-description').value = bodyText;

            alert('🚀 Ingestion Stream Complete! Metadata parsed into input states.');
          };
          reader.readAsText(file);
        }

        function executeMarkdownIngestionBlogs(file) {
          if (!file.name.endsWith('.md')) return alert('❌ Security Block: Only standard Markdown (.md) structures are accepted.');
          
          const reader = new FileReader();
          reader.onload = (e) => {
            const content = e.target.result;
            const frontmatterMatch = content.match(/^---\s*([\s\S]*?)\n---\s*([\s\S]*)$/);
            
            let meta = {}, bodyText = content;
            if (frontmatterMatch) {
              frontmatterMatch[1].split('\n').forEach(line => {
                const parts = line.split(':');
                if (parts.length >= 2) {
                  const key = parts[0].trim();
                  const val = parts.slice(1).join(':').trim().replace(/^["']|["']$/g, '');
                  meta[key] = val;
                }
              });
              bodyText = frontmatterMatch[2].trim();
            }

            if (meta.title) document.getElementById('form-title-blogs').value = meta.title;
            if (meta.tools) document.getElementById('form-tools-blogs').value = meta.tools;
            if (meta.isFeatured) {
              document.getElementById('form-is-featured-blogs').checked = (meta.isFeatured === 'true' || meta.isFeatured === true);
            }
            document.getElementById('form-description-blogs').value = bodyText;

            alert('🚀 Blog Ingestion Complete! Metadata parsed into Blog form.');
          };
          reader.readAsText(file);
        }

        const metaForm = document.getElementById('landing-meta-form');
        const metaBtn = document.getElementById('landing-submit-btn');
        if (metaForm && metaBtn) {
          metaForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            metaBtn.innerText = "DEPLOYING METADATA...";
            metaBtn.disabled = true;

            const payload = {
              heroFirstName: metaForm.querySelector('[name="heroFirstName"]').value.trim(),
              heroLastName: metaForm.querySelector('[name="heroLastName"]').value.trim(),
              heroSubtitle: metaForm.querySelector('[name="heroSubtitle"]').value.trim(),
              heroShortBio: metaForm.querySelector('[name="heroShortBio"]').value.trim(),
              aboutHeading: metaForm.querySelector('[name="aboutHeading"]').value.trim(),
              aboutLongDesc: metaForm.querySelector('[name="aboutLongDescription"]').value.trim(),
              coreDomains: metaForm.querySelector('[name="coreDomains"]').value.trim()
            };

            try {
              const res = await fetch('/api/landing-metadata', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
              const r = await res.json();
              if (r.success) {
                alert('🚀 CORE SITE METADATA FLUSHED AND LIVE SYNCED OUT!');
                window.location.reload();
              } else alert('❌ Commit Failure: ' + r.message);
            } catch {
              alert('❌ Connection Broken: Verify cloud configuration parameter strings.');
            } finally {
              metaBtn.innerText = "[ SAVE METADATA ]";
              metaBtn.disabled = false;
            }
          });
        }

        const projForm = document.getElementById('projects-matrix-form');
        const projBtn = document.getElementById('projects-submit-btn');
        let isEditing = false;
        let editingAssetId = null;

        async function fetchAndRenderProjects() {
          try {
            const res = await fetch('/api/projects-labs');
            const result = await res.json();
            if (result.success) {
              window.activeProjects = result.data;
              const tbody = document.getElementById('assets-tbody');
              if (tbody) {
                tbody.innerHTML = '';
                result.data.filter(p => p.type && (p.type.toLowerCase() === 'project' || p.type.toLowerCase() === 'lab')).forEach((proj, i) => {
                  const tr = document.createElement('tr');
                  tr.className = "hover:bg-slate-50/40 transition-colors duration-100";
                  const typeClass = proj.type === 'Project' ? 'bg-blue-50 text-blue-600 border border-blue-100/60' : 'bg-orange-50 text-orange-600 border border-orange-100/60';
                  tr.innerHTML = `
                    <td class="py-3 px-4 font-mono text-slate-400">#${i + 1}</td>
                    <td class="py-3 px-4 font-bold text-slate-900">${proj.title}</td>
                    <td class="py-3 px-4"><span class="px-2 py-0.5 rounded text-[9px] font-mono uppercase tracking-wider ${typeClass}">${proj.type}</span></td>
                    <td class="py-3 px-4 text-slate-500 font-mono max-w-xs truncate">${proj.tools}</td>
                    <td class="py-3 px-4 text-right whitespace-nowrap">
                      <button data-edit-id="${proj.id}" class="text-blue-500 hover:text-blue-700 font-mono font-bold hover:underline bg-transparent cursor-pointer border-none py-1 px-2 rounded hover:bg-blue-50/30 transition-all mr-2">EDIT</button>
                      <button data-delete-id="${proj.id}" class="text-red-500 hover:text-red-700 font-mono font-bold hover:underline bg-transparent cursor-pointer border-none py-1 px-2 rounded hover:bg-red-50/30 transition-all">DELETE</button>
                    </td>
                  `;
                  tbody.appendChild(tr);
                });
              }
            }
          } catch(err) {
            console.error('Failed to refresh table', err);
          }
        }

        document.addEventListener('click', async (e) => {
          const btnCancel = e.target.closest('#cancel-edit-btn');
          if (btnCancel) {
            e.preventDefault();
            e.stopPropagation();
            isEditing = false;
            editingAssetId = null;
            if (projForm) projForm.reset();
            const idInput = document.getElementById('form-asset-id');
            if (idInput) idInput.value = '';
            const badge = document.getElementById('edit-mode-badge');
            if (badge) badge.classList.add('hidden');
            if (projBtn) projBtn.innerText = "[ DEPLOY ASSET TO LIVE LAYER ]";
          }

          const btnEdit = e.target.closest('[data-edit-id]');
          if (btnEdit) {
            const id = btnEdit.getAttribute('data-edit-id');
            if (!window.activeProjects) {
              const res = await fetch('/api/projects-labs');
              const result = await res.json();
              if (result.success) window.activeProjects = result.data;
            }
            const proj = window.activeProjects?.find(p => p.id == id);
            if(proj) {
              isEditing = true;
              editingAssetId = proj.id;
              document.getElementById('form-asset-id').value = proj.id;
              document.getElementById('form-title').value = proj.title || '';
              document.getElementById('form-type').value = proj.type || 'Project';
              document.getElementById('form-tools').value = proj.technologyStack?.join(', ') || proj.tools || '';
              document.getElementById('form-description').value = proj.detailedContent || proj.description || '';
              document.getElementById('form-is-featured').checked = !!proj.isFeatured;
              if(document.getElementById('form-status')) document.getElementById('form-status').value = proj.status || 'Completed';
              if(document.getElementById('form-difficulty')) document.getElementById('form-difficulty').value = proj.difficulty || 'Intermediate';
              if(document.getElementById('form-cloud-provider')) document.getElementById('form-cloud-provider').value = proj.cloudProvider || '';
              if(document.getElementById('form-os')) document.getElementById('form-os').value = proj.operatingSystem || '';
              
              document.getElementById('edit-mode-badge').classList.remove('hidden');
              document.getElementById('edit-mode-title').innerText = proj.title;
              document.getElementById('projects-submit-btn').innerText = "UPDATE LIVE ASSET";
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          }

          const btnDel = e.target.closest('[data-delete-id]');
          if (btnDel) {
            const targetId = btnDel.getAttribute('data-delete-id');
            if (!confirm(`Are you strictly authorized to wipe asset node row #${targetId}?`)) return;
            
            try {
              const res = await fetch(`/api/projects-labs/${targetId}`, { method: 'DELETE' });
              const r = await res.json();
              if (r.success) {
                alert('🗑️ Operational Item purged from Neon ecosystem.');
                fetchAndRenderProjects();
              } else {
                alert('❌ Deletion failed: ' + r.message);
              }
            } catch {
              alert('❌ Net Connection Lost while hitting delete endpoint proxy.');
            }
          }
        });

        if (projForm && projBtn) {
          projForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            projBtn.innerText = isEditing ? "UPDATING ASSET..." : "EXECUTING SQL CLUSTER INSERT...";
            projBtn.disabled = true;

            const payload = {
              title: document.getElementById('form-title').value.trim(),
              type: document.getElementById('form-type').value,
              tools: document.getElementById('form-tools').value.trim(),
              description: document.getElementById('form-description').value.trim(),
              isFeatured: document.getElementById('form-is-featured').checked,
              status: document.getElementById('form-status')?.value || 'Completed',
              difficulty: document.getElementById('form-difficulty')?.value || 'Intermediate',
              cloudProvider: document.getElementById('form-cloud-provider')?.value || 'Unknown',
              operatingSystem: document.getElementById('form-os')?.value || 'Linux'
            };

            try {
              const method = isEditing ? 'PUT' : 'POST';
              const url = isEditing ? `/api/projects-labs/${editingAssetId}` : '/api/projects-labs';
              const response = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
              
              if (!response.ok) throw new Error(`Status: ${response.status}`);
              const result = await response.json();

              if (result.success) {
                alert(isEditing ? '🚀 ASSET NODE SUCCESSFULLY UPDATED!' : '🚀 ASSET NODE SUCCESSFULLY REGISTERED IN LIVE ENVIRONMENT!');
                isEditing = false;
                editingAssetId = null;
                projForm.reset();
                document.getElementById('form-asset-id').value = '';
                document.getElementById('edit-mode-badge').classList.add('hidden');
                projBtn.innerText = "[ DEPLOY ASSET TO LIVE LAYER ]";
                fetchAndRenderProjects();
              } else {
                alert('❌ Database Error: ' + result.message);
                projBtn.innerText = isEditing ? "UPDATE LIVE ASSET" : "[ DEPLOY ASSET TO LIVE LAYER ]";
              }
            } catch (err) {
              console.error(err);
              alert('❌ Pipe Failure: Verify the active status of your DATABASE_URL link parameters.');
              projBtn.innerText = isEditing ? "UPDATE LIVE ASSET" : "[ DEPLOY ASSET TO LIVE LAYER ]";
            } finally {
              projBtn.disabled = false;
            }
          });
        }

        
      const blogsForm = document.getElementById('blogs-matrix-form');
      if (blogsForm) {
        blogsForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = document.getElementById('blogs-submit-btn');
          const originalText = btn.innerText;
          btn.innerText = 'EXECUTING SQL CLUSTER INSERT...';
          btn.disabled = true;
          
          try {
            const data = {
              title: document.getElementById('form-title-blogs').value.trim(),
              type: 'Blog',
              tools: document.getElementById('form-tools-blogs').value.trim(),
              description: document.getElementById('form-description-blogs').value.trim(),
              isFeatured: document.getElementById('form-is-featured-blogs').checked
            };
            
            if (!data.title || !data.description) {
              alert('❌ Title and Description are required fields.');
              btn.innerText = originalText;
              btn.disabled = false;
              return;
            }

            const response = await fetch('/api/projects-labs', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
            
            const result = await response.json();
            if (result.success) {
              alert('🚀 BLOG NODE SUCCESSFULLY REGISTERED IN LIVE ENVIRONMENT!');
              window.location.reload();
            } else {
              alert('❌ Database Error: ' + result.message);
              btn.innerText = originalText;
              btn.disabled = false;
            }
          } catch (err) {
            console.error(err);
            alert('❌ Network error during blog deployment.');
            btn.innerText = originalText;
            btn.disabled = false;
          }
        });
      }

        // Delete handled above via event delegation.

        // --- Engineering Logs CRUD via Modal ---
        const capModal = document.getElementById('capability-modal');
        const capForm = document.getElementById('capability-form');
        const capTitle = document.getElementById('modal-title');
        const capCatInput = document.getElementById('modal-category');
        const capSkillInput = document.getElementById('modal-skill');
        const capLevelInput = document.getElementById('modal-level');
        const capClose = document.getElementById('modal-close');
        const capCancel = document.getElementById('modal-cancel');
        const capSubmitBtn = document.getElementById('modal-submit');

        const openModal = (category = '') => {
          capModal.classList.remove('hidden');
          capForm.reset();
          if (category) {
            capTitle.innerText = `Add Skill to [${category}]`;
            capCatInput.value = category;
            capCatInput.readOnly = true;
            capCatInput.classList.add('opacity-70', 'cursor-not-allowed');
          } else {
            capTitle.innerText = 'Add New Category & Skill';
            capCatInput.readOnly = false;
            capCatInput.classList.remove('opacity-70', 'cursor-not-allowed');
          }
          setTimeout(() => capSkillInput.focus(), 100);
        };

        const closeModal = () => {
          capModal.classList.add('hidden');
        };

        if (capClose) capClose.addEventListener('click', closeModal);
        if (capCancel) capCancel.addEventListener('click', closeModal);
        if (capModal) capModal.addEventListener('click', (e) => {
          if (e.target === capModal) closeModal();
        });

        const btnAddCategory = document.getElementById('btn-add-category');
        if (btnAddCategory) {
          btnAddCategory.addEventListener('click', () => openModal());
        }

        document.querySelectorAll('[data-add-skill-cat]').forEach(btn => {
          btn.addEventListener('click', () => {
            openModal(btn.getAttribute('data-add-skill-cat'));
          });
        });

        // Resume Profile
        const resumeForm = document.getElementById('resume-profile-form');
        const resumeSubmitBtn = document.getElementById('resume-submit-btn');

        if (resumeForm && resumeSubmitBtn) {
          resumeSubmitBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            resumeSubmitBtn.innerText = '[ SAVING... ]';
            resumeSubmitBtn.classList.add('opacity-50', 'cursor-wait');

            try {
              const parseJSON = (str, fallback) => {
                try { return JSON.parse(str); } catch (e) { return fallback; }
              };
              
              const payload = {
                fullName: resumeForm.querySelector('[name="fullName"]').value,
                jobTitle: resumeForm.querySelector('[name="jobTitle"]').value,
                email: resumeForm.querySelector('[name="email"]').value,
                phone: resumeForm.querySelector('[name="phone"]').value,
                location: resumeForm.querySelector('[name="location"]').value,
                linkedIn: resumeForm.querySelector('[name="linkedIn"]').value,
                github: resumeForm.querySelector('[name="github"]').value,
                website: resumeForm.querySelector('[name="website"]').value,
                summary: resumeForm.querySelector('[name="summary"]').value,
                experience: parseJSON(resumeForm.querySelector('[name="experience"]').value, []),
                education: parseJSON(resumeForm.querySelector('[name="education"]').value, []),
                certifications: parseJSON(resumeForm.querySelector('[name="certifications"]').value, []),
              };

              const res = await fetch('/api/resume', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });

              if (res.ok) {
                resumeSubmitBtn.innerText = '[ SAVED SUCCESSFULLY ]';
                resumeSubmitBtn.classList.replace('bg-blue-600', 'bg-green-600');
                resumeSubmitBtn.classList.replace('hover:bg-blue-700', 'hover:bg-green-700');
                setTimeout(() => {
                  resumeSubmitBtn.innerText = '[ SAVE RESUME PROFILE ]';
                  resumeSubmitBtn.classList.replace('bg-green-600', 'bg-blue-600');
                  resumeSubmitBtn.classList.replace('hover:bg-green-700', 'hover:bg-blue-700');
                  resumeSubmitBtn.classList.remove('opacity-50', 'cursor-wait');
                }, 2000);
              } else {
                alert('Failed to save Resume Profile.');
                resumeSubmitBtn.innerText = '[ SAVE RESUME PROFILE ]';
                resumeSubmitBtn.classList.remove('opacity-50', 'cursor-wait');
              }
            } catch (error) {
              alert('Network error while saving Resume Profile.');
              resumeSubmitBtn.innerText = '[ SAVE RESUME PROFILE ]';
              resumeSubmitBtn.classList.remove('opacity-50', 'cursor-wait');
            }
          });
        }

        if (capForm) {
          capForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const category = capCatInput.value.trim();
            const skillName = capSkillInput.value.trim();
            const level = capLevelInput.value;
            
            if (!category || !skillName) return alert('Category and Skill Name are required.');
            
            capSubmitBtn.disabled = true;
            capSubmitBtn.innerText = 'SAVING...';
            
            try {
              const res = await fetch('/api/capabilities', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ category, skillName, level, orderIndex: 99 })
              });
              if (res.ok) {
                window.location.reload();
              } else {
                alert('Failed to save capability.');
                capSubmitBtn.disabled = false;
                capSubmitBtn.innerText = 'SAVE';
              }
            } catch (err) {
              alert('Network error.');
              capSubmitBtn.disabled = false;
              capSubmitBtn.innerText = 'SAVE';
            }
          });
        }

        document.querySelectorAll('[data-delete-cap-id]').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-delete-cap-id');
            if (!confirm(`Are you sure you want to delete this skill?`)) return;
            
            try {
              const res = await fetch(`/api/capabilities/${id}`, { method: 'DELETE' });
              if (res.ok) window.location.reload();
              else alert('Failed to delete skill.');
            } catch (err) {
              alert('Network error.');
            }
          });
        });

        // Handling Resume Builder Delete
        document.querySelectorAll('[data-delete-resume-id]').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            if(!confirm('Are you sure you want to delete this resume?')) return;
            const id = (e.currentTarget as HTMLElement).getAttribute('data-delete-resume-id');
            const originalText = (e.currentTarget as HTMLElement).innerText;
            (e.currentTarget as HTMLElement).innerText = '...';
            try {
              const res = await fetch(`/api/builder?id=${id}`, { method: 'DELETE' });
              if (res.ok) {
                window.location.reload();
              } else {
                alert('Failed to delete resume');
                (e.currentTarget as HTMLElement).innerText = originalText;
              }
            } catch (err) {
              alert('Network error');
              (e.currentTarget as HTMLElement).innerText = originalText;
            }
          });
        });

        // Handling Create New Resume
        const createResumeBtn = document.getElementById('create-resume-btn');
        if (createResumeBtn) {
          createResumeBtn.addEventListener('click', async (e) => {
            const btn = e.currentTarget as HTMLElement;
            const originalText = btn.innerHTML;
            btn.innerHTML = 'Creating...';
            try {
              const res = await fetch('/api/builder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  title: 'Untitled Resume',
                  template: 'harvard',
                  content: {
                    personal: { fullName: '', headline: '', city: '', state: '', country: '', phone: '', email: '', linkedIn: '', portfolio: '', github: '' },
                    summary: '',
                    education: [],
                    experience: [],
                    projects: [],
                    leadership: [],
                    certifications: [],
                    awards: [],
                    skills: { soft: [], cloud: [], other: [], tools: [], devops: [], database: [], frameworks: [], programming: [] },
                    languages: []
                  }
                })
              });
              const json = await res.json();
              if (json.success && json.data && json.data.id) {
                window.location.href = `/admin/builder?id=${json.data.id}`;
              } else {
                alert('Failed to create resume');
                btn.innerHTML = originalText;
              }
            } catch (err) {
              alert('Error creating resume');
              btn.innerHTML = originalText;
            }
          });
        }
      });
    </script>
  </body>
</html>
