---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { db } from '../db/index';
import { projectsLabs } from '../db/schema';
import { desc } from 'drizzle-orm';

let publishedBlogs: typeof projectsLabs.$inferSelect[] = [];
try {
  publishedBlogs = await db.select().from(projectsLabs).orderBy(desc(projectsLabs.id));
  publishedBlogs = publishedBlogs.filter(p => p.type === 'Blog');
} catch (error) {
  console.error("Database connection error:", error);
}

const cleanDescription = (text: string | null) => {
  if (!text) return { text: '' };
  let cleanText = text.replace(/<[^>]*>?/gm, '').replace(/[#*`_]/g, '');
  return { text: cleanText.substring(0, 150) + (cleanText.length > 150 ? '...' : '') };
};
---

<BaseLayout title="Blog | Developer Portfolio">
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-24 space-y-16">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="text-blue-600 font-mono text-sm mb-4"># vaqihdev_telemetry_logs</div>
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-4">Technical Write-ups</h1>
      <p class="text-slate-500 text-sm">Cloud architecture breakdowns, deployment post-mortems, and engineering insights.</p>
    </div>

    {publishedBlogs.length > 0 ? (
      <div class="grid gap-6">
        {publishedBlogs.map(blog => (
          <a href={`/blog/${blog.id}`} class="group block relative bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-6 md:p-8 rounded-xl shadow-sm hover:shadow-xl hover:border-blue-500 dark:hover:border-blue-500 transition-all duration-300">
            {/* Cyber Corner Accents */}
            <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-transparent group-hover:border-blue-500 transition-colors -mt-px -ml-px rounded-tl-xl"></div>
            <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-transparent group-hover:border-blue-500 transition-colors -mb-px -mr-px rounded-br-xl"></div>

            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <time class="text-xs font-mono text-blue-600 dark:text-blue-400 font-bold uppercase tracking-widest">
                    'Published recently'
                  </time>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {blog.title}
                </h2>
                <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
                  {cleanDescription(blog.description).text}
                </p>
                {blog.tools && (
                  <div class="flex gap-2 flex-wrap mt-6">
                    {(blog.tools ? blog.tools.split(',') : []).map(tag => (
                      <span class="text-[10px] font-mono px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-500 rounded uppercase tracking-widest">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              
              <div class="hidden md:flex shrink-0 items-center justify-center w-12 h-12 rounded-full border border-slate-200 dark:border-slate-800 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/20 group-hover:border-blue-500 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-slate-500 font-mono text-sm border border-dashed border-slate-300 dark:border-slate-700 rounded-xl">
        No published blogs found in the database.
      </div>
    )}
  </main>
</BaseLayout>
