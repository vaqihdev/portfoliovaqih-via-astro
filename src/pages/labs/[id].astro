---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { db } from '../../db';
import { engineeringAssets } from '../../db/schema';
import { eq, and, inArray } from 'drizzle-orm';
import { marked } from 'marked';

const { id } = Astro.params;

let lab = null;
try {
  const result = await db.select().from(engineeringAssets).where(and(inArray(engineeringAssets.type, ['Lab', 'Blog']), eq(engineeringAssets.id, Number(id)))).limit(1);
  if (result && result.length > 0) {
    const raw = result[0];
    lab = {
      ...raw,
      tools: (raw.technologyStack as string[])?.join(', ') || '',
      description: raw.detailedContent
    };
  }
} catch (e) {
  console.error("Error fetching lab:", e);
}

if (!lab) {
  return Astro.redirect('/404');
}

// Convert markdown to HTML
const htmlContent = marked.parse(lab.description);
---

<Layout title={`${lab.title} | Engineering Labs`}>
  <Navbar />
  
  <main class="w-full max-w-4xl mx-auto px-6 py-24 flex flex-col gap-10 min-h-[80vh] relative z-10">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-2 font-mono">
      <a href="/labs" class="hover:text-blue-600 hover:underline">Labs</a>
      <span>/</span>
      <span class="text-slate-900 font-semibold">{lab.title}</span>
    </div>

    <div class="bg-white border border-slate-300 rounded-lg shadow-sm overflow-hidden">
      <div class="border-b border-slate-200 bg-slate-50 px-8 py-6">
        <div class="flex items-center justify-between mb-4">
          <span class={`px-2 py-0.5 rounded text-[9px] font-mono font-bold uppercase tracking-wider ${lab.type === 'Project' ? 'bg-blue-50 text-blue-600 border border-blue-100/50' : 'bg-orange-50 text-orange-600 border border-orange-100/50'}`}>
            {lab.type}
          </span>
          <span class="text-[10px] text-slate-400 font-mono tracking-widest uppercase">
            NODE_#{lab.id}
          </span>
        </div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-4">{lab.title}</h1>
        
        <div class="flex flex-wrap gap-2">
          {lab.tools.split(',').map((tool: string) => (
            <span class="px-2.5 py-1 bg-white border border-slate-200 text-slate-600 font-mono text-[10px] rounded-md shadow-sm">
              {tool.trim()}
            </span>
          ))}
        </div>
      </div>
      
      <div class="p-8 prose prose-slate max-w-none prose-headings:font-bold prose-a:text-blue-600 hover:prose-a:text-blue-700 prose-img:rounded-lg prose-img:border prose-img:border-slate-200 prose-img:shadow-sm" set:html={htmlContent}>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  /* Basic prose styles for the markdown content since we don't have typography plugin */
  .prose h1 { font-size: 2.25rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 800; line-height: 1.2; color: #0f172a; }
  .prose h2 { font-size: 1.5rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 700; line-height: 1.33; color: #0f172a; }
  .prose h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.5rem; font-weight: 600; line-height: 1.6; color: #0f172a; }
  .prose p { margin-top: 1.25rem; margin-bottom: 1.25rem; line-height: 1.75; color: #334155; }
  .prose a { text-decoration: underline; font-weight: 500; }
  .prose img { max-width: 100%; height: auto; margin-top: 2rem; margin-bottom: 2rem; }
  .prose ul { margin-top: 1.25rem; margin-bottom: 1.25rem; padding-left: 1.625em; list-style-type: disc; }
  .prose ol { margin-top: 1.25rem; margin-bottom: 1.25rem; padding-left: 1.625em; list-style-type: decimal; }
  .prose li { margin-top: 0.5rem; margin-bottom: 0.5rem; }
  .prose blockquote { font-weight: 500; font-style: italic; color: #1e293b; border-left-width: 0.25rem; border-left-color: #cbd5e1; quotes: "\201C""\201D""\2018""\2019"; margin-top: 1.6em; margin-bottom: 1.6em; padding-left: 1em; }
  .prose code { color: #0f172a; font-weight: 600; font-size: 0.875em; background-color: #f1f5f9; padding: 0.2em 0.4em; border-radius: 0.25rem; }
  .prose pre { color: #e2e8f0; background-color: #1e293b; overflow-x: auto; font-size: 0.875em; line-height: 1.7142857; margin-top: 1.7142857em; margin-bottom: 1.7142857em; border-radius: 0.375rem; padding: 0.8571429em 1.1428571em; }
  .prose pre code { background-color: transparent; border-width: 0; border-radius: 0; padding: 0; font-weight: inherit; color: inherit; font-size: inherit; font-family: inherit; line-height: inherit; }
  .prose hr { border-color: #e2e8f0; border-top-width: 1px; margin-top: 3em; margin-bottom: 3em; }
</style>
