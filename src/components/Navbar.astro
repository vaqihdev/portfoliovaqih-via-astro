---
import Logo from './Logo.astro';
---
<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/90 dark:bg-slate-950/90 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="hover:opacity-80 transition-opacity flex items-center gap-2">
      <Logo />
    </a>
    <nav class="hidden md:flex space-x-8 text-sm font-semibold tracking-wide text-slate-500 dark:text-slate-400">
      <a href="/" class="text-blue-600 dark:text-blue-500 border-b-2 border-blue-600 pb-1 -mb-[18px]">Home</a>
      <a href="/projects" class="hover:text-slate-900 dark:hover:text-white transition-colors pb-1">Projects</a>
      <a href="/blog" class="hover:text-slate-900 dark:hover:text-white transition-colors pb-1">Blog</a>
      <a href="/resume" class="hover:text-slate-900 dark:hover:text-white transition-colors pb-1">Resume</a>
    </nav>
  </div>
</header>
