---
// Telemetry.astro
---
<div class="relative bg-slate-950 rounded-xl shadow-2xl border border-slate-800 overflow-hidden w-full max-w-lg mx-auto md:mx-0">
  <div class="flex items-center px-4 py-3 bg-slate-900 border-b border-slate-800">
    <div class="flex gap-2">
      <div class="w-3 h-3 rounded-full bg-red-500"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-green-500"></div>
    </div>
    <div class="mx-auto text-xs font-mono text-slate-500">Muchamad Ghufron Vaqih [Version 3.8.2026]</div>
  </div>
  <div class="p-6 text-sm font-mono text-slate-300 space-y-2 h-[250px]">
    <p><span class="text-green-400">User: sum up vaqihdev@1.infra.internal | Linux Kernel: 6.8.0-generic</span></p>
    <p>Type 'help' to view standard commands.</p>
    <div class="flex mt-4 items-center">
      <span class="text-blue-500 font-bold">vaqihdev:~$</span>
      <span class="w-2 h-4 bg-slate-300 animate-pulse ml-2"></span>
    </div>
  </div>

  <!-- Interactive Widget Overlay -->
  <div class="absolute bottom-0 left-0 right-0 p-4 bg-white/10 dark:bg-black/20 backdrop-blur-md border-t border-slate-700/50">
    <div class="flex justify-between items-center text-xs font-mono">
      <div class="flex items-center gap-2">
        <span class="text-blue-400">●</span>
        <span class="text-slate-300">Infrastructure_Telemetry</span>
      </div>
      <div class="flex items-center gap-2 text-slate-400">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        LIVE
      </div>
    </div>
    <div class="grid grid-cols-4 gap-2 mt-4">
      <div class="bg-slate-900 p-2 rounded border border-slate-800 flex flex-col justify-between">
        <div class="text-[10px] text-slate-500 uppercase">Latency</div>
        <div class="text-lg font-bold text-slate-200 mt-2">31<span class="text-[10px] font-normal text-slate-500 ml-1">ms</span></div>
      </div>
      <div class="bg-slate-900 p-2 rounded border border-slate-800 flex flex-col justify-between">
        <div class="text-[10px] text-slate-500 uppercase">CPU Host</div>
        <div class="text-lg font-bold text-slate-200 mt-2">76<span class="text-[10px] font-normal text-slate-500 ml-1">%</span></div>
        <div class="w-full bg-slate-800 h-1 mt-1 rounded-full"><div class="bg-red-500 h-1 rounded-full w-[76%]"></div></div>
      </div>
      <div class="bg-slate-900 p-2 rounded border border-slate-800 flex flex-col justify-between">
        <div class="text-[10px] text-slate-500 uppercase">Memory</div>
        <div class="text-lg font-bold text-slate-200 mt-2">55.4<span class="text-[10px] font-normal text-slate-500 ml-1">%</span></div>
        <div class="w-full bg-slate-800 h-1 mt-1 rounded-full"><div class="bg-yellow-500 h-1 rounded-full w-[55.4%]"></div></div>
      </div>
      <div class="bg-slate-900 p-2 rounded border border-slate-800 flex flex-col justify-between">
        <div class="text-[10px] text-slate-500 uppercase">Traffic</div>
        <div class="text-lg font-bold text-slate-200 mt-2">20<span class="text-[10px] font-normal text-slate-500 ml-1">Gbps</span></div>
      </div>
    </div>
  </div>
</div>
