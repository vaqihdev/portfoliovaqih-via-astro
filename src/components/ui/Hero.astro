---
// Hero.astro
---
<section id="home" class="grid md:grid-cols-2 gap-12 items-center">
  <div class="space-y-6">
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">
      Muchamad <br />
      <span class="text-blue-600 font-mono italic font-normal tracking-tighter">Ghufron Vaqih</span>
    </h1>
    <div class="text-sm font-mono text-slate-500 uppercase tracking-widest border-l-2 border-slate-300 dark:border-slate-700 pl-4 py-1">
      [ Cloud Infrastructure Engineer & DevOps Architect ]
    </div>
    <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed max-w-lg pt-4">
      An engineer with a developer's soul and a systems architect's vision. I build secure, automated, highly available, and resilient cloud infrastructure that empowers modern engineering teams.
    </p>
    <div class="flex gap-4 pt-4">
      <a href="#projects" class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 font-semibold px-6 py-3 rounded text-sm transition-colors flex items-center gap-2">
        EXPLORE PROJECTS
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
      <a href="#resume" class="bg-transparent border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:border-slate-400 dark:hover:border-slate-500 font-semibold px-6 py-3 rounded text-sm transition-colors">
        REVIEW RESUME
      </a>
    </div>
  </div>

  <div class="relative bg-slate-950 rounded-xl shadow-2xl border border-slate-800 overflow-hidden mt-8 md:mt-0">
    <div class="flex items-center px-4 py-3 bg-slate-900 border-b border-slate-800">
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
      </div>
      <div class="mx-auto text-xs font-mono text-slate-500">Muchamad Ghufron Vaqih [Version 3.8.2026]</div>
    </div>
    <div class="p-6 text-sm font-mono text-slate-300 space-y-2 h-[250px]">
      <p><span class="text-green-400">User: sum up vaqihdev@1.infra.internal | Linux Kernel: 6.8.0-generic</span></p>
      <p>Type 'help' to view standard commands.</p>
      <div class="flex mt-4 items-center">
        <span class="text-blue-500 font-bold">vaqihdev:~$</span>
        <span class="w-2 h-4 bg-slate-300 animate-pulse ml-2"></span>
      </div>
    </div>

    <!-- Interactive Widget Overlay -->
    <div class="absolute bottom-0 left-0 right-0 p-4 bg-white/10 dark:bg-black/20 backdrop-blur-md border-t border-slate-700/50">
      <div class="flex justify-between items-center text-xs font-mono">
        <div class="flex items-center gap-2">
          <span class="text-blue-400">●</span>
          <span class="text-slate-300">Infrastructure_Telemetry</span>
        </div>
        <div class="text-slate-400">LIVE</div>
      </div>
      <div class="grid grid-cols-4 gap-2 mt-4">
        <div class="bg-slate-900 p-2 rounded border border-slate-800">
          <div class="text-[10px] text-slate-500 uppercase">Latency</div>
          <div class="text-lg font-bold text-slate-200">31<span class="text-[10px] font-normal text-slate-500 ml-1">ms</span></div>
        </div>
        <div class="bg-slate-900 p-2 rounded border border-slate-800">
          <div class="text-[10px] text-slate-500 uppercase">CPU Host</div>
          <div class="text-lg font-bold text-slate-200">76<span class="text-[10px] font-normal text-slate-500 ml-1">%</span></div>
          <div class="w-full bg-slate-800 h-1 mt-1 rounded-full"><div class="bg-red-500 h-1 rounded-full w-3/4"></div></div>
        </div>
        <div class="bg-slate-900 p-2 rounded border border-slate-800">
          <div class="text-[10px] text-slate-500 uppercase">Memory</div>
          <div class="text-lg font-bold text-slate-200">55.4<span class="text-[10px] font-normal text-slate-500 ml-1">%</span></div>
          <div class="w-full bg-slate-800 h-1 mt-1 rounded-full"><div class="bg-yellow-500 h-1 rounded-full w-1/2"></div></div>
        </div>
        <div class="bg-slate-900 p-2 rounded border border-slate-800">
          <div class="text-[10px] text-slate-500 uppercase">Traffic</div>
          <div class="text-lg font-bold text-slate-200">20<span class="text-[10px] font-normal text-slate-500 ml-1">Gbps</span></div>
        </div>
      </div>
    </div>
  </div>
</section>
