---
// Capabilities.astro
import { db } from '../../db';
import { capabilities } from '../../db/schema';
import { asc } from 'drizzle-orm';

const allCapabilities = await db.select().from(capabilities).orderBy(asc(capabilities.orderIndex)).catch(() => []);

// Group capabilities by category
const categories = [...new Set(allCapabilities.map(cap => cap.category))];
const groupedCapabilities = categories.map(category => {
  return {
    category,
    items: allCapabilities.filter(cap => cap.category === category)
  };
});
---
<section class="pt-20 border-t border-slate-200 dark:border-slate-800">
  <div class="text-center max-w-2xl mx-auto mb-16">
    <div class="text-blue-600 font-mono text-sm mb-4"># vaqihdev_skills</div>
    <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Cloud & DevOps Capabilities</h2>
    <p class="text-slate-500 text-sm">Automated tools, containerization platforms, and systems knowledge mapped by sheer field application.</p>
  </div>

  {groupedCapabilities.length > 0 ? (
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {groupedCapabilities.map(group => (
        <div class="relative bg-white dark:bg-slate-900 border border-blue-200 dark:border-blue-900/30 rounded p-6 shadow-sm">
          {/* Corner accents resembling tech UI */}
          <div class="absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2 border-blue-500 -mt-px -ml-px"></div>
          <div class="absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2 border-blue-500 -mt-px -mr-px"></div>
          <div class="absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2 border-blue-500 -mb-px -ml-px"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2 border-blue-500 -mb-px -mr-px"></div>

          <div class="flex justify-between items-center mb-6">
            <h3 class="text-xs font-mono font-bold tracking-widest uppercase text-blue-600 dark:text-blue-400">{group.category}</h3>
            <div class="text-[10px] font-mono text-slate-400">DATA_SET</div>
          </div>
          
          <ul class="space-y-4">
            {group.items.map(item => (
              <li class="flex items-center justify-between group">
                <span class="text-sm font-semibold text-slate-700 dark:text-slate-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors uppercase tracking-wider">{item.skillName}</span>
                <span class="text-[10px] font-mono px-2 py-0.5 border rounded text-blue-600 border-blue-200 dark:text-blue-400 dark:border-blue-800/50 bg-blue-50 dark:bg-blue-900/10 uppercase tracking-widest">{item.level}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  ) : (
    <div class="grid md:grid-cols-3 gap-6">
      {/* Mock data to show the layout when empty collections */}
      {['DATABASE', 'FRONTEND', 'ENGINEERING TOOLS'].map(cat => (
        <div class="relative bg-white dark:bg-slate-900 border border-blue-200 dark:border-blue-900/30 rounded p-6 shadow-sm opacity-50">
           <div class="absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2 border-blue-500 -mt-px -ml-px"></div>
          <div class="absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2 border-blue-500 -mt-px -mr-px"></div>
          <div class="absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2 border-blue-500 -mb-px -ml-px"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2 border-blue-500 -mb-px -mr-px"></div>
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-xs font-mono font-bold tracking-widest uppercase text-blue-600 dark:text-blue-400">{cat}</h3>
            <div class="text-[10px] font-mono text-slate-400">DATA_SET</div>
          </div>
          <div class="space-y-4">
             <div class="flex items-center justify-between"><span class="text-sm font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider">Example Tech</span><span class="text-[10px] font-mono px-2 py-0.5 border rounded text-blue-600 border-blue-200 uppercase tracking-widest">Mock</span></div>
          </div>
        </div>
      ))}
    </div>
  )}
</section>
