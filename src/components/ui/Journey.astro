---
// Journey.astro
import { getCollection } from 'astro:content';

const allExperience = await getCollection('experience');
const experience = allExperience.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---
<section id="resume" class="pt-20 border-t border-slate-200 dark:border-slate-800">
  <div class="text-center max-w-2xl mx-auto mb-16">
    <div class="text-blue-600 font-mono text-sm mb-4"># vaqihdev_journey</div>
    <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">The Career Journey</h2>
    <p class="text-slate-500 text-sm">How my development expertise and strict compliance standards converge into reliable cloud engineering.</p>
  </div>

  <div class="max-w-3xl mx-auto relative">
    {experience.length > 0 ? (
      <div class="space-y-12 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-300 dark:before:via-slate-700 before:to-transparent">
        {experience.map((job, index) => (
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
            <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white dark:border-slate-950 bg-slate-200 dark:bg-slate-800 text-blue-500 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10 transition-colors group-hover:bg-blue-500 group-hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><circle cx="8" cy="12" r="6"/></svg>
            </div>
            
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm transition-shadow hover:shadow-md">
              <div class="flex items-center justify-between mb-1">
                <div class="text-xs font-mono text-blue-600 dark:text-blue-500 font-bold">
                  {job.data.startDate.getFullYear()} - {job.data.current ? 'PRESENT' : job.data.endDate?.getFullYear()}
                </div>
              </div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white">{job.data.role}</h3>
              <div class="text-sm text-slate-500 font-medium mb-4">{job.data.company}</div>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                {job.data.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-slate-500 font-mono text-sm border border-dashed border-slate-300 dark:border-slate-700 rounded-xl">
        No experience data available.
      </div>
    )}
  </div>
</section>
